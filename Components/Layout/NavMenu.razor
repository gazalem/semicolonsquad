@implements IDisposable

@using System.Security.Claims

@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">SmartFoodPlanner</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="ingredients">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span>
                Ingredients
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="favorites">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span>
                Favorite Recipes
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="mealplan">
                <span class="bi bi-calendar2-week-fill-nav-menu" aria-hidden="true"></span>
                Meal Plan
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="cookbook">
                <span class="bi bi-book-fill-nav-menu" aria-hidden="true"></span>
                Cookbook
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="pastplans">
                <span class="bi bi-clock-history-nav-menu" aria-hidden="true"></span>
                Past Plans
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Sign out
                        </button>
                    </form>
                </div>
                <div class="nav-item px-3">
                    <div class="nav-link text-light small">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span>
                        @GetDisplayName(context.User)
                    </div>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="bi bi-google" aria-hidden="true"></span>
                        Sign in with Google
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    private static string GetDisplayName(ClaimsPrincipal user)
    {
        return user.FindFirstValue(ClaimTypes.GivenName)
            ?? user.FindFirstValue(ClaimTypes.Name)
            ?? user.FindFirstValue(ClaimTypes.Email)
            ?? "Account";
    }

    private static string? GetEmail(ClaimsPrincipal user)
    {
        return user.FindFirstValue(ClaimTypes.Email);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

