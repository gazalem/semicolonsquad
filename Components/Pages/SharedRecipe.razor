@page "/share/{Token}"
@rendermode InteractiveServer

@using SmartFoodPlanner.Models
@using SmartFoodPlanner.Services

@inject IMealPlanService MealPlanService

<PageTitle>@(recipe?.Name ?? "Shared Recipe")</PageTitle>

<section class="recipe-page">
    @if (isLoading)
    {
        <div class="recipe-state" role="status">
            <span class="spinner-border text-success" aria-hidden="true"></span>
            <p>Setting the table...</p>
        </div>
    }
    else if (recipe is null)
    {
        <div class="recipe-state not-found" role="alert">
            <span aria-hidden="true">🍽️</span>
            <h1>Recipe not found</h1>
            <p>This link may be incorrect or the recipe may have been removed.</p>
            <a class="btn btn-primary" href="/">Go home</a>
        </div>
    }
    else
    {
        <header class="recipe-hero">
            <div>
                <p class="eyebrow">@recipe.Day's dinner</p>
                <h1>@recipe.Name</h1>
                <span class="time-badge">⏱ @EstimatedTime</span>
            </div>
        </header>

        <div class="recipe-content">
            <section class="recipe-panel ingredients-panel">
                <div class="section-heading">
                    <span aria-hidden="true">🥕</span>
                    <div><p class="eyebrow">What you'll need</p><h2>Ingredients</h2></div>
                </div>
                @if (Ingredients.Count == 0)
                {
                    <p class="empty-copy">No ingredients were provided.</p>
                }
                else
                {
                    <ul class="ingredient-list">
                        @foreach (var ingredient in Ingredients)
                        {
                            <li>@ingredient</li>
                        }
                    </ul>
                }
            </section>

            <section class="recipe-panel instructions-panel">
                <div class="section-heading">
                    <span aria-hidden="true">👩‍🍳</span>
                    <div><p class="eyebrow">Let's cook</p><h2>Instructions</h2></div>
                </div>
                @if (Steps.Count == 0)
                {
                    <p class="empty-copy">No instructions were provided.</p>
                }
                else
                {
                    <ol class="step-list">
                        @foreach (var step in Steps)
                        {
                            <li><span>@step</span></li>
                        }
                    </ol>
                }
            </section>
        </div>
    }
</section>

@code {
    [Parameter]
    public string Token { get; set; } = string.Empty;

    private Recipe? recipe;
    private bool isLoading = true;

    private IReadOnlyList<string> Ingredients => RecipeTextFormatter.ParseIngredients(recipe?.Ingredients);
    private IReadOnlyList<string> Steps => RecipeTextFormatter.ParseSteps(recipe?.Instructions);
    private string EstimatedTime => RecipeTextFormatter.GetEstimatedTime(recipe);

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        recipe = string.IsNullOrWhiteSpace(Token) ? null : await MealPlanService.GetRecipeByTokenAsync(Token);
        isLoading = false;
    }
}
