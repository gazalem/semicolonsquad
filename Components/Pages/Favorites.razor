@page "/favorites"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using SmartFoodPlanner.Data
@using SmartFoodPlanner.Models

@inject ApplicationDbContext DbContext
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Favorite Recipes</PageTitle>

<section class="responsive-page">
<h1>Favorite Recipes</h1>

<p class="text-secondary">Keep recipes generated by the app so they stay connected to your profile.</p>

<div class="row g-4 responsive-page-grid">
    <div class="col-lg-5">
        <EditForm Model="recipeInput" OnValidSubmit="SaveRecipeAsync">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="form-floating mb-3">
                <InputText id="recipe-title" class="form-control" @bind-Value="recipeInput.Title" placeholder="Recipe title" />
                <label for="recipe-title">Recipe title</label>
            </div>

            <div class="form-floating mb-3">
                <InputTextArea id="recipe-ingredients" class="form-control recipe-textarea" @bind-Value="recipeInput.Ingredients" placeholder="Ingredients" />
                <label for="recipe-ingredients">Ingredients</label>
            </div>

            <div class="form-floating mb-3">
                <InputTextArea id="recipe-instructions" class="form-control recipe-textarea" @bind-Value="recipeInput.Instructions" placeholder="Instructions" />
                <label for="recipe-instructions">Instructions</label>
            </div>

            <button type="submit" class="btn btn-primary">@SubmitLabel</button>
            @if (editingRecipeId is not null)
            {
                <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CancelRecipeEdit">Cancel</button>
            }
        </EditForm>
    </div>

    <div class="col-lg-7">
        @if (favoriteRecipes.Count == 0)
        {
            <p class="text-secondary">No favorite recipes saved yet.</p>
        }
        else
        {
            <div class="list-group">
                @foreach (var recipe in favoriteRecipes)
                {
                    <article class="list-group-item">
                        <div class="saved-item-layout">
                            <h2 class="h5 mb-2">@recipe.Title</h2>
                            <div class="saved-item-actions">
                                <button type="button" class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditRecipe(recipe)">Edit</button>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteRecipeAsync(recipe)">Delete</button>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(recipe.Ingredients))
                        {
                            <p class="mb-2"><strong>Ingredients:</strong> @recipe.Ingredients</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(recipe.Instructions))
                        {
                            <p class="mb-0"><strong>Instructions:</strong> @recipe.Instructions</p>
                        }
                    </article>
                }
            </div>
        }
    </div>
</div>
</section>

@code {
    private readonly RecipeInput recipeInput = new();
    private List<FavoriteRecipe> favoriteRecipes = [];
    private string userId = string.Empty;
    private int? editingRecipeId;

    private string SubmitLabel => editingRecipeId is null ? "Save favorite" : "Update favorite";

    protected override async Task OnInitializedAsync()
    {
        userId = await GetCurrentUserIdAsync();
        await LoadFavoriteRecipesAsync();
    }

    private async Task SaveRecipeAsync()
    {
        if (editingRecipeId is null)
        {
            DbContext.FavoriteRecipes.Add(new FavoriteRecipe
            {
                UserId = userId,
                Title = recipeInput.Title.Trim(),
                Ingredients = NormalizeOptionalText(recipeInput.Ingredients),
                Instructions = NormalizeOptionalText(recipeInput.Instructions)
            });
        }
        else
        {
            var recipe = await DbContext.FavoriteRecipes
                .FirstOrDefaultAsync(item => item.Id == editingRecipeId && item.UserId == userId);

            if (recipe is not null)
            {
                recipe.Title = recipeInput.Title.Trim();
                recipe.Ingredients = NormalizeOptionalText(recipeInput.Ingredients);
                recipe.Instructions = NormalizeOptionalText(recipeInput.Instructions);
            }
        }

        await DbContext.SaveChangesAsync();
        CancelRecipeEdit();
        await LoadFavoriteRecipesAsync();
    }

    private void EditRecipe(FavoriteRecipe recipe)
    {
        editingRecipeId = recipe.Id;
        recipeInput.Title = recipe.Title;
        recipeInput.Ingredients = recipe.Ingredients;
        recipeInput.Instructions = recipe.Instructions;
    }

    private async Task DeleteRecipeAsync(FavoriteRecipe recipe)
    {
        var savedRecipe = await DbContext.FavoriteRecipes
            .FirstOrDefaultAsync(item => item.Id == recipe.Id && item.UserId == userId);

        if (savedRecipe is not null)
        {
            DbContext.FavoriteRecipes.Remove(savedRecipe);
            await DbContext.SaveChangesAsync();
            await LoadFavoriteRecipesAsync();
        }
    }

    private async Task LoadFavoriteRecipesAsync()
    {
        favoriteRecipes = await DbContext.FavoriteRecipes
            .Where(recipe => recipe.UserId == userId)
            .OrderBy(recipe => recipe.Title)
            .ToListAsync();
    }

    private void CancelRecipeEdit()
    {
        editingRecipeId = null;
        recipeInput.Title = string.Empty;
        recipeInput.Ingredients = string.Empty;
        recipeInput.Instructions = string.Empty;
    }

    private async Task<string> GetCurrentUserIdAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return authState.User.FindFirstValue(ClaimTypes.NameIdentifier)
            ?? throw new InvalidOperationException("Unable to find the signed-in user.");
    }

    private static string? NormalizeOptionalText(string? value)
    {
        var trimmed = value?.Trim();
        return string.IsNullOrWhiteSpace(trimmed) ? null : trimmed;
    }

    private sealed class RecipeInput
    {
        [Required]
        [StringLength(150)]
        public string Title { get; set; } = string.Empty;

        [StringLength(1000)]
        public string? Ingredients { get; set; }

        [StringLength(2000)]
        public string? Instructions { get; set; }
    }
}
