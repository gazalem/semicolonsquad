@page "/mealplan"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization

<PageTitle>Meal Plan</PageTitle>

<h1>Meal Plan</h1>

<p class="text-secondary">Map out simple meal ideas for the week and keep a note of what needs attention.</p>

<div class="row g-4">
    <div class="col-lg-4">
        <EditForm Model="planInput" OnValidSubmit="SavePlanAsync">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="form-floating mb-3">
                <InputText id="plan-name" class="form-control" @bind-Value="planInput.Name" placeholder="Plan name" />
                <label for="plan-name">Plan name</label>
            </div>

            <div class="form-floating mb-3">
                <InputTextArea id="plan-notes" class="form-control" style="min-height: 120px;" @bind-Value="planInput.Notes" placeholder="Notes" />
                <label for="plan-notes">Notes</label>
            </div>

            <button type="submit" class="btn btn-primary">@SubmitLabel</button>
            @if (editingPlanId is not null)
            {
                <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CancelPlanEdit">Cancel</button>
            }
        </EditForm>
    </div>

    <div class="col-lg-8">
        @if (mealPlans.Count == 0)
        {
            <p class="text-secondary">No meal plans created yet.</p>
        }
        else
        {
            <div class="list-group">
                @foreach (var plan in mealPlans)
                {
                    <article class="list-group-item">
                        <div class="d-flex justify-content-between gap-3">
                            <div>
                                <h2 class="h5 mb-2">@plan.Name</h2>
                                @if (!string.IsNullOrWhiteSpace(plan.Notes))
                                {
                                    <p class="mb-0 text-secondary">@plan.Notes</p>
                                }
                            </div>
                            <div class="text-nowrap">
                                <button type="button" class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditPlan(plan)">Edit</button>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeletePlan(plan)">Delete</button>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</div>

@code {
    private readonly PlanInput planInput = new();
    private List<MealPlanEntry> mealPlans = [];
    private int? editingPlanId;
    private int nextId = 1;

    private string SubmitLabel => editingPlanId is null ? "Add plan" : "Save plan";

    private void SavePlanAsync()
    {
        if (editingPlanId is null)
        {
            mealPlans.Add(new MealPlanEntry
            {
                Id = nextId++,
                Name = planInput.Name.Trim(),
                Notes = NormalizeOptionalText(planInput.Notes)
            });
        }
        else
        {
            var plan = mealPlans.FirstOrDefault(item => item.Id == editingPlanId);
            if (plan is not null)
            {
                plan.Name = planInput.Name.Trim();
                plan.Notes = NormalizeOptionalText(planInput.Notes);
            }
        }

        CancelPlanEdit();
    }

    private void EditPlan(MealPlanEntry plan)
    {
        editingPlanId = plan.Id;
        planInput.Name = plan.Name;
        planInput.Notes = plan.Notes;
    }

    private void DeletePlan(MealPlanEntry plan)
    {
        mealPlans.RemoveAll(item => item.Id == plan.Id);
    }

    private void CancelPlanEdit()
    {
        editingPlanId = null;
        planInput.Name = string.Empty;
        planInput.Notes = string.Empty;
    }

    private static string? NormalizeOptionalText(string? value)
    {
        var trimmed = value?.Trim();
        return string.IsNullOrWhiteSpace(trimmed) ? null : trimmed;
    }

    private sealed class PlanInput
    {
        [Required]
        [StringLength(100)]
        public string Name { get; set; } = string.Empty;

        [StringLength(500)]
        public string? Notes { get; set; }
    }

    private sealed class MealPlanEntry
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Notes { get; set; }
    }
}
