@page "/mealplan"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Authorization
@using SmartFoodPlanner.Models
@using SmartFoodPlanner.Services

@inject IAIService AIService
@inject IMealPlanService MealPlanService
@inject IIngredientService IngredientService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Weekly Meal Plan</PageTitle>

<section class="meal-plan-page">
    <header class="plan-hero">
        <p class="eyebrow">Fresh ideas for your pantry</p>
        <h1>This Week's Meal Plan</h1>
        <p>Turn the ingredients you have into seven quick, practical dinners.</p>
        <button class="btn btn-primary generate-button" type="button" disabled="@isGenerating" @onclick="GeneratePlanAsync">
            @if (isGenerating)
            {
                <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                <span>Generating…</span>
            }
            else
            {
                <span>Generate This Week's Plan</span>
            }
        </button>
    </header>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="error-banner" role="alert">
            <strong>We couldn't prepare your plan.</strong>
            <span>@errorMessage</span>
        </div>
    }

    @if (isGenerating)
    {
        <div class="loading-state" role="status" aria-live="polite">
            <div class="cooking-spinner" aria-hidden="true">🍳</div>
            <h2>Cooking up your plan...</h2>
            <p>This can take a moment while we match meals to your pantry.</p>
        </div>
    }
    else if (currentPlan is not null)
    {
        <div class="week-heading">
            <div>
                <p class="eyebrow">Your seven-day lineup</p>
                <h2>Dinner is decided</h2>
            </div>
            <span class="generated-date">Generated @currentPlan.GeneratedAt.ToLocalTime().ToString("MMM d")</span>
        </div>

        <div class="weekly-grid">
            @foreach (var recipe in OrderedRecipes)
            {
                var dayNumber = GetDayNumber(recipe.Day);
                <button class="day-card" type="button" @onclick="() => OpenRecipe(recipe.Id)" aria-label="Open @recipe.Name for @recipe.Day">
                    <div class="day-label">Day @dayNumber <span>@recipe.Day</span></div>
                    <div class="meal-icon" aria-hidden="true">@GetMealIcon(dayNumber)</div>
                    <h3>@recipe.Name</h3>
                    <span class="time-badge">⏱ @GetEstimatedTime(recipe)</span>
                    <span class="view-recipe">View recipe →</span>
                </button>
            }
        </div>
    }
    else
    {
        <div class="empty-plan">
            <span aria-hidden="true">📅</span>
            <h2>Your week is a blank canvas</h2>
            <p>Generate a plan to see Monday through Sunday meal ideas here.</p>
        </div>
    }
</section>

@code {
    private static readonly string[] Days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];
    private SmartFoodPlanner.Models.MealPlan? currentPlan;
    private string userId = string.Empty;
    private string? errorMessage;
    private bool isGenerating;

    private IEnumerable<Recipe> OrderedRecipes => currentPlan is null
        ? Enumerable.Empty<Recipe>()
        : currentPlan.Recipes.OrderBy(recipe => Array.FindIndex(Days, day => day.Equals(recipe.Day, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
        userId = user.FindFirstValue(ClaimTypes.NameIdentifier)
            ?? throw new InvalidOperationException("Unable to find the signed-in user.");
    }

    private async Task GeneratePlanAsync()
    {
        if (isGenerating) return;

        isGenerating = true;
        errorMessage = null;

        try
        {
            var ingredients = await IngredientService.GetIngredientsAsync(userId);
            var ingredientNames = ingredients.Select(item => item.Name).ToList();
            var response = await AIService.GenerateMealPlanAsync(ingredientNames);

            if (response.Recipes.Count != 7)
            {
                throw new InvalidOperationException("The generator returned an incomplete week. Please try again.");
            }

            currentPlan = await MealPlanService.SaveMealPlanAsync(userId, response);
        }
        catch (Exception)
        {
            errorMessage = "Something went wrong while generating meals. Check that the AI service is running, then try again.";
        }
        finally
        {
            isGenerating = false;
        }
    }

    private void OpenRecipe(int recipeId) => Navigation.NavigateTo($"/recipe/{recipeId}");

    private static int GetDayNumber(string day)
    {
        var index = Array.FindIndex(Days, item => item.Equals(day, StringComparison.OrdinalIgnoreCase));
        return index < 0 ? 1 : index + 1;
    }

    private static string GetMealIcon(int dayNumber) => dayNumber switch
    {
        1 => "🥗", 2 => "🍝", 3 => "🌮", 4 => "🍲", 5 => "🍛", 6 => "🥘", _ => "🍽️"
    };

    private static string GetEstimatedTime(Recipe recipe)
    {
        var minutes = ParseMinutes(recipe.PrepTime) + ParseMinutes(recipe.CookTime);
        return minutes > 0 ? $"{minutes} min" : recipe.CookTime ?? recipe.PrepTime ?? "30 min";
    }

    private static int ParseMinutes(string? value)
    {
        var match = Regex.Match(value ?? string.Empty, @"\d+");
        return match.Success && int.TryParse(match.Value, out var minutes) ? minutes : 0;
    }
}
